{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperclip.ai/schemas/plant-knowledge/v1",
  "title": "Plant Knowledge Unified Schema",
  "description": "Unified data schema for plant botanical, chemical, cultivation, therapeutic, market, and quality data — optimized for AI training, knowledge graphs, and RAG systems.",
  "version": "1.0.0",
  "type": "object",
  "required": ["metadata", "plant_identification"],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Dataset metadata and provenance",
      "required": ["plant_name", "date", "version"],
      "properties": {
        "plant_name": {
          "type": "string",
          "description": "Primary common name of the plant"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date of data compilation"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
          "description": "Semantic version of the dataset"
        },
        "researcher": {
          "type": "string",
          "description": "Agent or researcher who compiled the data"
        },
        "confidence_legend": {
          "type": "object",
          "description": "Explanation of confidence levels used throughout",
          "properties": {
            "high": { "type": "string" },
            "medium": { "type": "string" },
            "low": { "type": "string" }
          }
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        },
        "sources_cited": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Aggregated list of all sources cited in the dataset"
        },
        "data_gaps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Flagged missing data requiring follow-up collection"
        }
      }
    },
    "plant_identification": {
      "type": "object",
      "description": "Taxonomic and identification information",
      "required": ["scientific_name", "family"],
      "properties": {
        "scientific_name": {
          "type": "string",
          "description": "Full scientific name with authority"
        },
        "authority": {
          "type": "string",
          "description": "Botanical authority citation"
        },
        "synonyms": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Accepted synonyms (including basionym)"
        },
        "family": {
          "type": "string",
          "description": "Botanical family (with common name in parentheses)"
        },
        "genus": { "type": "string" },
        "species": { "type": "string" },
        "taxonomic_rank": {
          "type": "string",
          "enum": ["Species", "Subspecies", "Variety", "Form", "Hybrid"]
        },
        "ncbi_taxonomy_id": {
          "type": "string",
          "description": "NCBI Taxonomy database identifier"
        },
        "classification": {
          "type": "object",
          "properties": {
            "kingdom": { "type": "string" },
            "clade": {
              "type": "array",
              "items": { "type": "string" }
            },
            "order": { "type": "string" },
            "family": { "type": "string" },
            "genus": { "type": "string" }
          }
        },
        "common_names": {
          "type": "object",
          "description": "Common names keyed by language code",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "morphology": {
          "type": "object",
          "description": "Physical description of the plant",
          "properties": {
            "growth_habit": { "type": "string" },
            "height": {
              "type": "object",
              "properties": {
                "typical": { "type": "string" },
                "maximum": { "type": "string" }
              }
            },
            "crown": { "type": "string" },
            "trunk": {
              "type": "object",
              "properties": {
                "diameter": { "type": "string" },
                "bark": { "type": "string" }
              }
            },
            "leaves": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "length": { "type": "string" },
                "leaflet_count": { "type": "string" },
                "leaflet_description": { "type": "string" },
                "color": { "type": "string" }
              }
            },
            "flowers": {
              "type": "object",
              "properties": {
                "inflorescence": { "type": "string" },
                "flower_count": { "type": "string" },
                "symmetry": { "type": "string" },
                "size": { "type": "string" },
                "color": { "type": "string" },
                "fragrance": { "type": "string" },
                "calyx": { "type": "string" },
                "petals": { "type": "string" },
                "staminal_tube": { "type": "string" },
                "ovary": { "type": "string" },
                "stigma": { "type": "string" }
              }
            },
            "fruit": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "shape": { "type": "string" },
                "size": { "type": "string" },
                "color": { "type": "string" },
                "exocarp": { "type": "string" },
                "mesocarp": { "type": "string" },
                "endocarp": { "type": "string" }
              }
            },
            "seed": {
              "type": "object",
              "properties": {
                "shape": { "type": "string" },
                "testa": { "type": "string" },
                "seeds_per_kg": { "type": "string" }
              }
            },
            "root_system": { "type": "string" }
          }
        },
        "native_range": {
          "type": "object",
          "properties": {
            "region": { "type": "string" },
            "countries": {
              "type": "array",
              "items": { "type": "string" }
            },
            "habitat": { "type": "string" }
          }
        },
        "current_distribution": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "regions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "elevation_range": { "type": "string" }
          }
        },
        "varieties_and_subspecies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "notes": { "type": "string" },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              }
            }
          }
        },
        "phenology": {
          "type": "object",
          "properties": {
            "flowering_season": {
              "type": "object",
              "description": "Keyed by region"
            },
            "fruiting_period": {
              "type": "object",
              "properties": {
                "fruit_development": { "type": "string" }
              }
            },
            "optimal_harvest_window": {
              "type": "object",
              "properties": {
                "seeds": { "type": "string" },
                "leaves": { "type": "string" }
              }
            },
            "age_at_first_fruiting": { "type": "string" },
            "lifespan": { "type": "string" }
          }
        },
        "pollination": { "type": "string" },
        "seed_dispersal": { "type": "string" },
        "differentiation_from_lookalikes": {
          "type": "object",
          "properties": {
            "species": { "type": "string" },
            "key_differences": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "chemical_composition": {
      "type": "object",
      "description": "Phytochemical profile and compound details",
      "properties": {
        "primary_bioactive_class": {
          "type": "string",
          "description": "Primary class of bioactive compounds"
        },
        "total_identified_compounds": {
          "type": "string",
          "description": "Number or range of identified phytochemicals"
        },
        "compound_families": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Major compound families present"
        },
        "key_compounds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "role"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "molecular_formula": { "type": "string" },
              "molecular_weight": { "type": "string" },
              "role": { "type": "string" },
              "evidence_type": {
                "type": "string",
                "enum": ["scientific_consensus", "single_study", "traditional_knowledge", "preliminary"]
              },
              "concentrations_by_plant_part": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "confidence_concentration": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "primary_source": { "type": "string" },
              "stability": {
                "type": "object",
                "properties": {
                  "photostability": { "type": "object" },
                  "thermal_stability": { "type": "object" },
                  "pH_stability": { "type": "object" },
                  "storage_recommendations": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "notes": { "type": "string" }
            }
          }
        },
        "oil_composition": {
          "type": "object",
          "description": "Fixed oil composition where applicable",
          "properties": {
            "oil_content_in_kernel": { "type": "string" },
            "fatty_acid_profile": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "standardization_markers": {
          "type": "object",
          "properties": {
            "values": {
              "type": "array",
              "items": { "type": "string" }
            },
            "confidence": {
              "type": "string",
              "enum": ["high", "medium", "low"]
            }
          }
        },
        "known_synergistic_interactions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "evidence_type": { "type": "string" },
              "evidence": { "type": "string" },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              }
            }
          }
        },
        "compound_stability_summary": {
          "type": "object",
          "properties": {
            "factor_light": { "type": "string" },
            "factor_temperature": { "type": "string" },
            "factor_pH": { "type": "string" },
            "factor_oxygen": { "type": "string" },
            "factor_moisture": { "type": "string" },
            "shelf_life_formulations": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "cultivation_data": {
      "type": "object",
      "description": "Agricultural and cultivation information",
      "properties": {
        "climate": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "optimal_temperature": { "type": "string" },
            "maximum_temperature": { "type": "string" },
            "minimum_temperature": { "type": "string" },
            "frost_tolerance": { "type": "string" },
            "annual_rainfall_optimal": { "type": "string" },
            "drought_tolerance": { "type": "string" },
            "tolerance_to_waterlogging": { "type": "string" },
            "altitude_range": { "type": "string" },
            "light_requirement": { "type": "string" }
          }
        },
        "soil": {
          "type": "object",
          "properties": {
            "pH_optimal": { "type": "string" },
            "pH_tolerable": { "type": "string" },
            "pH_notes": { "type": "string" },
            "texture": {
              "type": "array",
              "items": { "type": "string" }
            },
            "drainage": { "type": "string" },
            "tolerant_soils": {
              "type": "array",
              "items": { "type": "string" }
            },
            "intolerant_soils": {
              "type": "array",
              "items": { "type": "string" }
            },
            "organic_matter": { "type": "string" },
            "calcium_mining": { "type": "string" }
          }
        },
        "propagation": {
          "type": "object",
          "properties": {
            "seed": {
              "type": "object",
              "properties": {
                "viability": { "type": "string" },
                "germination_rate": { "type": "string" },
                "germination_time": { "type": "string" },
                "seed_treatment": { "type": "string" },
                "sowing_depth": { "type": "string" },
                "seeds_per_kg": { "type": "string" },
                "storage_behavior": { "type": "string" }
              }
            },
            "vegetative_propagation": {
              "type": "object",
              "properties": {
                "cuttings": { "type": "string" },
                "air_layering": { "type": "string" },
                "grafting": { "type": "string" }
              }
            },
            "tissue_culture": {
              "type": "object",
              "properties": {
                "methods": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "notes": { "type": "string" },
                "confidence": {
                  "type": "string",
                  "enum": ["high", "medium", "low"]
                }
              }
            }
          }
        },
        "planting": {
          "type": "object",
          "properties": {
            "season": { "type": "string" },
            "pit_size": { "type": "string" },
            "pit_filling": { "type": "string" },
            "spacing": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "seedling_age_at_transplanting": { "type": "string" },
            "planting_density_notes": { "type": "string" }
          }
        },
        "irrigation": {
          "type": "object",
          "properties": {
            "establishment_phase": { "type": "string" },
            "mature_trees": { "type": "string" },
            "drought_tolerance": { "type": "string" },
            "irrigation_methods": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "fertilizer_and_nutrients": {
          "type": "object",
          "properties": {
            "general_requirement": { "type": "string" },
            "at_planting": { "type": "string" },
            "established_trees": { "type": "string" },
            "NPK_demand": { "type": "string" },
            "organic_practice": { "type": "string" }
          }
        },
        "intercropping_compatibility": {
          "type": "object",
          "properties": {
            "compatible_crops": {
              "type": "array",
              "items": { "type": "string" }
            },
            "notes": { "type": "string" },
            "windbreak_benefit": { "type": "string" },
            "systems": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "pest_and_disease_management": {
          "type": "object",
          "properties": {
            "common_pests": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "control": { "type": "string" }
                }
              }
            },
            "common_diseases": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "control": { "type": "string" }
                }
              }
            },
            "organic_control_methods": {
              "type": "array",
              "items": { "type": "string" }
            },
            "inherent_resistance": { "type": "string" }
          }
        },
        "harvesting": {
          "type": "object",
          "properties": {
            "maturity_indicators": {
              "type": "object",
              "properties": {
                "seeds_fruits": { "type": "string" },
                "leaves": { "type": "string" }
              }
            },
            "harvest_method": {
              "type": "object",
              "properties": {
                "seeds": { "type": "string" },
                "leaves": { "type": "string" }
              }
            },
            "season": {
              "type": "object",
              "description": "Keyed by region"
            },
            "frequency": { "type": "string" },
            "yield_per_tree": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "yield_per_hectare": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "yield_confidence": {
              "type": "string",
              "enum": ["high", "medium", "low"]
            },
            "tree_production_lifespan": { "type": "string" }
          }
        },
        "post_harvest_handling": {
          "type": "object",
          "properties": {
            "depulping": { "type": "string" },
            "seed_drying": { "type": "string" },
            "seed_storage": { "type": "string" },
            "leaf_drying": { "type": "string" },
            "bark_drying": { "type": "string" },
            "processing_for_oil": {
              "type": "array",
              "items": { "type": "string" }
            },
            "oil_storage": { "type": "string" },
            "quality_preservation": { "type": "string" }
          }
        },
        "growth_rates": {
          "type": "object",
          "properties": {
            "height_at_5_years": { "type": "string" },
            "height_at_10_years": { "type": "string" },
            "height_at_25_years": { "type": "string" },
            "mean_annual_girth_increment": { "type": "string" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "therapeutic_applications": {
      "type": "object",
      "description": "Therapeutic uses, evidence, and clinical data",
      "properties": {
        "traditional_medicine_systems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "system": { "type": "string" },
              "traditions": {
                "type": "object",
                "properties": {
                  "classical_texts": { "type": "string" },
                  "first_mentioned": { "type": "string" },
                  "sanskrit_names": { "type": "string" }
                }
              },
              "pharmacology": {
                "type": "object",
                "properties": {
                  "rasa_taste": { "type": "string" },
                  "virya_potency": { "type": "string" },
                  "vipaka_post_digestive": { "type": "string" },
                  "guna_qualities": { "type": "string" },
                  "karma_actions": { "type": "string" }
                }
              },
              "classical_categorization": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "key_indications": {
                "type": "array",
                "items": { "type": "string" }
              },
              "dosage_forms": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "form": { "type": "string" },
                    "dose": { "type": "string" },
                    "vehicle": { "type": "string" },
                    "preparation": { "type": "string" },
                    "route": { "type": "string" }
                  }
                }
              },
              "classical_formulations": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "modern_therapeutic_categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "details": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "mechanisms_of_action": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "mechanism": { "type": "string" },
              "compound": { "type": "string" },
              "effect": { "type": "string" },
              "evidence_level": { "type": "string" },
              "source_doi": { "type": "string" }
            }
          }
        },
        "safety_profile": {
          "type": "object",
          "properties": {
            "toxicity_data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "parameter": { "type": "string" },
                  "value": { "type": "string" },
                  "source_doi": { "type": "string" }
                }
              }
            },
            "adverse_effects": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "severity": { "type": "string" },
                  "effects": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "population": { "type": "string" },
                  "evidence_level": { "type": "string" }
                }
              }
            },
            "contraindications": {
              "type": "array",
              "items": { "type": "string" }
            },
            "drug_interactions": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "clinical_evidence": {
      "type": "object",
      "description": "Clinical trial data and evidence review",
      "properties": {
        "evidence_quality_framework": { "type": "string" },
        "overall_assessment": { "type": "string" },
        "key_clinical_trials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "condition": { "type": "string" },
              "study_title": { "type": "string" },
              "design": { "type": "string" },
              "n": { "type": "string" },
              "intervention": { "type": "string" },
              "duration": { "type": "string" },
              "comparator": { "type": "string" },
              "key_findings": {
                "type": "array",
                "items": { "type": "string" }
              },
              "quality_rating": { "type": "string" },
              "source_doi": { "type": "string" },
              "source_pmid": { "type": "string" },
              "clinicaltrials_gov_id": { "type": "string" },
              "status": { "type": "string" },
              "evidence_distinction": { "type": "string" }
            }
          }
        },
        "evidence_summary_by_condition": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "condition": { "type": "string" },
              "total_studies": { "type": "string" },
              "best_evidence": { "type": "string" },
              "effect_size": { "type": "string" },
              "grade": { "type": "string" }
            }
          }
        },
        "ongoing_clinical_trials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "clinicaltrials_gov_id": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" },
              "sponsor": { "type": "string" },
              "phase": { "type": "string" }
            }
          }
        },
        "evidence_gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "market_data": {
      "type": "object",
      "description": "Market intelligence and commercial data",
      "properties": {
        "market_size": {
          "type": "object",
          "properties": {
            "estimates": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "source": { "type": "string" },
                  "year": { "type": "string" },
                  "value_usd": { "type": "string" },
                  "forecast_year": { "type": "string" },
                  "forecast_value_usd": { "type": "string" },
                  "cagr": { "type": "string" },
                  "scope": { "type": "string" }
                }
              }
            },
            "consensus_estimate": {
              "type": "object",
              "properties": {
                "current_market_2025": { "type": "string" },
                "projected_2034": { "type": "string" },
                "consensus_cagr": { "type": "string" }
              }
            }
